# ============================================
# Step 1: Notion Integration トークンを設定
# ============================================
# 取得: https://www.notion.so/my-integrations → 新規作成 → トークンコピー
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# ============================================
# Step 2: DB を配置する親ページの URL を設定
# ============================================
# → この後 ./bin/init-db.sh を実行して DB を自動作成
# 例: https://www.notion.so/yourworkspace/PageName-abc123def456
NOTION_PARENT_PAGE_URL=

# ============================================
# Step 3: 作成された DB の URL を設定
# ============================================
# → init-db.sh 実行後に表示される URL を貼る
# 例: https://www.notion.so/yourworkspace/abc123def456?v=...
NOTION_DB_URL=

# === オプション ===

# 処理間の待機秒数（Notion API レート制限対策、デフォルト: 1）
WAIT_SECONDS=1

# ログレベル（debug / info / warn / error、デフォルト: info）
LOG_LEVEL=info
