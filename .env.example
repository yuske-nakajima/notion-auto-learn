# === 必須 ===

# Notion Integration トークン
# 取得: https://www.notion.so/my-integrations → 新規作成 → トークンコピー
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# Notion データベースの URL（ブラウザのアドレスバーからコピー）
# 例: https://www.notion.so/yourworkspace/abc123def456?v=...
# DB ID は自動抽出するので URL をそのまま貼ればOK
NOTION_DB_URL=https://www.notion.so/yourworkspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DB を作成する親ページの URL（init-db で使用）
# 例: https://www.notion.so/yourworkspace/PageName-abc123def456
# DB 作成後は不要（NOTION_DB_URL を使用）
NOTION_PARENT_PAGE_URL=https://www.notion.so/yourworkspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === オプション ===

# 処理間の待機秒数（Notion API レート制限対策、デフォルト: 1）
WAIT_SECONDS=1

# ログレベル（debug / info / warn / error、デフォルト: info）
LOG_LEVEL=info
